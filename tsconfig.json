{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["vitest/globals", "node"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["index.ts", "src/**/*.ts", "tests/**/*.ts", "vitest.config.ts", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
