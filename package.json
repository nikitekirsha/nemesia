{
  "name": "nemesia",
  "version": "1.1.3",
  "description": "A tiny library for binding declarative JS components to existing HTML.",
  "main": "./dist/nemesia.js",
  "module": "./dist/nemesia.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/nemesia.umd.js",
  "jsdelivr": "./dist/nemesia.umd.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nemesia.js",
      "default": "./dist/nemesia.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && vite build && tsc -p tsconfig.build.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit --target ES2022 --module ESNext --moduleResolution Bundler --lib ES2022,DOM examples/**/*.ts",
    "example": "vite examples/$npm_config_id"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikitekirsha/nemesia.git"
  },
  "keywords": [
    "nemesia",
    "components",
    "lifecycle",
    "vanilla",
    "dom",
    "progressive-enhancement"
  ],
  "author": "nikitekirsha",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nikitekirsha/nemesia/issues"
  },
  "homepage": "https://github.com/nikitekirsha/nemesia#readme",
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
